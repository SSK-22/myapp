pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Docker Build') {
            steps {
                bat 'docker build -t myapp .'
            }
        }

        stage('Run') {
            steps {
                bat 'docker rm -f myapp-container'
                bat 'docker run --name myapp-container myapp'
            }
        }
        post {
        success {
            archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
        }
    }
    }
}